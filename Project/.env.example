# Core runtime
ENVIRONMENT=dev
DEBUG=True
SECRET_KEY=change-me

# Network / host
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=
REAL_ADMIN_PATH=admin

# Mật khẩu sau khi phục hồi tenant demo (Jazzmin → Phục hồi dữ liệu demo)
DEMO_SEED_DEFAULT_PASSWORD=123456

# Database
# - ENVIRONMENT=prod: bắt buộc dùng POSTGRES_*
# - ENVIRONMENT=dev: để trống POSTGRES_DB để dùng SQLite
SQLITE_NAME=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_CONN_MAX_AGE=60

# Security
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0

# Logging
LOG_LEVEL=INFO

# Realtime
REDIS_URL=redis://127.0.0.1:6379
